---
layout: none
permalink: /search.json
---
[
  {% for post in site.posts %}
  {
    "title"    : {{ post.title | strip | jsonify }},
    "category" : {{ post.category | strip | jsonify }},
    "tags"     : {{ post.tags | join: ', ' | strip | jsonify }},
    "content"  : {{ post.content | strip_html | strip_newlines | strip | jsonify }},
    "url"      : {{ post.url | relative_url | jsonify }},
    "date"     : {{ post.date | date: "%Y-%m-%d" | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
  {% if site.pages.size > 0 %},{% endif %}
  {% for page in site.pages %}
  {% if page.title and page.url != "/404.html" and page.url != "/search.json" %}
  {
    "title"    : {{ page.title | strip | jsonify }},
    "category" : {{ page.category | strip | jsonify }},
    "tags"     : {{ page.tags | join: ', ' | strip | jsonify }},
    "content"  : {{ page.content | strip_html | strip_newlines | strip | jsonify }},
    "url"      : {{ page.url | relative_url | jsonify }},
    "date"     : {{ page.date | date: "%Y-%m-%d" | default: "" | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endif %}
  {% endfor %}
]